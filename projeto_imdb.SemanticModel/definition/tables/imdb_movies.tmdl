	column filming_location_(clean) =
			
			IF(
			    ISBLANK([filming_location]),
			    "Desconhecido",
			    [filming_location]
			)
		lineageTag: 3bcb1018-b57d-488d-8ed4-791bb2049592
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Status de Critica' =
			
			IF(
			    [rating_imdb] >= 8,
			    "Excelente",
			    "Comum"
			)
		lineageTag: 42b4ed15-c236-4ac3-92ca-b0cb1eee3ac7
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

