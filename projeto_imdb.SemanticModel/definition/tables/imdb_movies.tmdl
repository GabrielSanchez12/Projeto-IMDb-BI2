table imdb_movies
	lineageTag: 7e761946-92e3-4944-adf0-4346376e3672

	measure nota_media_pos_2000 =
			
			CALCULATE(
			    AVERAGE([rating_imdb]),
			    imdb_movies[ano] >= 2000
			)
		lineageTag: d7ee1f55-effa-443a-9030-476cd7500a9b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Resultado Financeiro Total (em $USD)' =
			
			SUMX(
			    imdb_movies,
			    imdb_movies[faturamento_global] - imdb_movies[orcamento]
			)
		formatString: #,0.00
		lineageTag: 2b35ca68-0c87-43bc-b905-58ede418fc2b

	measure 'Quantidade de Filmes' =
			
			DISTINCTCOUNT(imdb_movies[id])
		formatString: 0.00
		lineageTag: 795f0a82-d7f6-4e96-a97e-f5637813e947

	measure nota_media_ate_2000 =
			
			CALCULATE(
			    AVERAGE([rating_imdb]),
			    imdb_movies[ano] <= 2000
			)
		lineageTag: 0fce7343-8918-4d38-bd16-f3fd2a693d64

		annotation PBI_FormatHint = {"isGeneralNumber":true}

